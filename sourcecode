import os
import json
import winreg
import zipfile
import tkinter as tk
from tkinter import filedialog
from tqdm import tqdm
import sys
import shutil
import requests
import hashlib

# -----------------------------
# Paths / config
# -----------------------------
if getattr(sys, "frozen", False):
    SCRIPT_DIR = os.path.dirname(sys.executable)
else:
    SCRIPT_DIR = os.path.dirname(os.path.abspath(__file__))

CONFIG_FILE = os.path.join(SCRIPT_DIR, "config.json")
ZIP_FILE_NAME = "paks.zip"
ZIP_FILE_PATH = os.path.join(SCRIPT_DIR, ZIP_FILE_NAME)
PARTS_DIR = os.path.join(SCRIPT_DIR, "download_parts")

# GitHub raw JSON manifest. Change this if your repo/path changes.
# Example GitHub file location: StayLiquidy/AFFWKG/main/link.json
MANIFEST_URL = "https://raw.githubusercontent.com/StayLiquidy/AFFWKG/refs/heads/main/link.json"

# Optional fallback manifest if GitHub is down. Leave files empty unless needed.
FALLBACK_MANIFEST = {
    "version": "fallback",
    "zip_name": "paks.zip",
    "files": []
}

REQUEST_TIMEOUT = 30
CHUNK_SIZE = 1024 * 1024  # 1 MB


# -----------------------------
# Steam / ARK detection
# -----------------------------
def get_steam_path_from_registry():
    try:
        with winreg.OpenKey(winreg.HKEY_CURRENT_USER, r"Software\\Valve\\Steam") as key:
            steam_path, _ = winreg.QueryValueEx(key, "SteamPath")
            return steam_path
    except Exception:
        return None


def find_additional_library_folders(steam_path):
    vdf_path = os.path.join(steam_path, "steamapps", "libraryfolders.vdf")
    library_paths = [os.path.join(steam_path, "steamapps", "common")]

    if os.path.exists(vdf_path):
        try:
            with open(vdf_path, "r", encoding="utf-8", errors="ignore") as f:
                for line in f:
                    if '"path"' in line or line.strip().startswith('"'):
                        parts = line.strip().split('"')
                        # Newer Steam VDF commonly has: "path"  "D:\\SteamLibrary"
                        if len(parts) >= 5 and os.path.exists(parts[3]):
                            library_paths.append(os.path.join(parts[3], "steamapps", "common"))
        except Exception:
            pass

    # De-duplicate while preserving order
    seen = set()
    clean_paths = []
    for path in library_paths:
        norm = os.path.normcase(os.path.normpath(path))
        if norm not in seen:
            seen.add(norm)
            clean_paths.append(path)
    return clean_paths


def find_ark_install_path():
    steam_path = get_steam_path_from_registry()
    if not steam_path:
        return None

    library_paths = find_additional_library_folders(steam_path)
    ark_subpath = os.path.join("ARK Survival Ascended", "ShooterGame", "Content", "Paks")

    for lib_path in library_paths:
        ark_path = os.path.join(lib_path, ark_subpath)
        if os.path.exists(ark_path):
            return ark_path

    return None


# -----------------------------
# Config helpers
# -----------------------------
def load_config():
    if os.path.exists(CONFIG_FILE):
        try:
            with open(CONFIG_FILE, "r", encoding="utf-8") as f:
                return json.load(f)
        except Exception:
            return {}
    return {}


def save_config(config):
    with open(CONFIG_FILE, "w", encoding="utf-8") as f:
        json.dump(config, f, indent=2)


def select_destination_folder(config):
    root = tk.Tk()
    root.withdraw()
    folder_selected = filedialog.askdirectory(title="Select ARK Paks Destination Folder")
    if folder_selected:
        config["destination_folder"] = folder_selected.replace("\\", "/")
        save_config(config)
    return folder_selected


# -----------------------------
# Manifest / Pixeldrain helpers
# -----------------------------
def normalize_pixeldrain_url(url):
    """Accept either https://pixeldrain.com/u/ID or https://pixeldrain.com/api/file/ID."""
    url = url.strip()
    if "pixeldrain.com/u/" in url:
        file_id = url.split("pixeldrain.com/u/", 1)[1].split("?", 1)[0].split("/", 1)[0]
        return f"https://pixeldrain.com/api/file/{file_id}"
    return url


def get_manifest():
    try:
        print("Fetching latest Pixeldrain manifest from GitHub...")
        r = requests.get(MANIFEST_URL, timeout=REQUEST_TIMEOUT)
        r.raise_for_status()
        manifest = r.json()
    except Exception as e:
        print(f"Failed to fetch manifest from GitHub: {e}")
        print("Using fallback manifest.")
        manifest = FALLBACK_MANIFEST

    if not isinstance(manifest, dict):
        raise ValueError("Manifest must be a JSON object.")

    files = manifest.get("files", [])
    if not files or not isinstance(files, list):
        raise ValueError("Manifest must contain a non-empty 'files' list.")

    normalized_files = []
    for item in files:
        if isinstance(item, str):
            normalized_files.append({"url": normalize_pixeldrain_url(item)})
        elif isinstance(item, dict) and "url" in item:
            copied = dict(item)
            copied["url"] = normalize_pixeldrain_url(copied["url"])
            normalized_files.append(copied)
        else:
            raise ValueError("Each manifest file must be a URL string or object with a 'url'.")

    manifest["files"] = normalized_files
    manifest.setdefault("version", "unknown")
    manifest.setdefault("zip_name", ZIP_FILE_NAME)
    return manifest


def manifest_signature(manifest):
    stable = json.dumps(manifest, sort_keys=True).encode("utf-8")
    return hashlib.sha256(stable).hexdigest()


def sha256_file(path):
    h = hashlib.sha256()
    with open(path, "rb") as f:
        for block in iter(lambda: f.read(1024 * 1024), b""):
            h.update(block)
    return h.hexdigest()


def download_file(url, output_path, expected_sha256=None):
    temp_path = output_path + ".download"
    resume_header = {}
    existing_size = 0

    if os.path.exists(temp_path):
        existing_size = os.path.getsize(temp_path)
        if existing_size > 0:
            resume_header["Range"] = f"bytes={existing_size}-"

    with requests.get(url, stream=True, timeout=REQUEST_TIMEOUT, headers=resume_header) as r:
        # If server does not support resume, restart from zero.
        if r.status_code == 200 and existing_size > 0:
            existing_size = 0
            resume_header = {}
            try:
                os.remove(temp_path)
            except FileNotFoundError:
                pass
            return download_file(url, output_path, expected_sha256)

        r.raise_for_status()

        total_header = r.headers.get("content-length")
        total_size = int(total_header) + existing_size if total_header else None
        mode = "ab" if existing_size > 0 else "wb"

        print(f"Downloading: {os.path.basename(output_path)}")
        with open(temp_path, mode) as f, tqdm(
            total=total_size,
            initial=existing_size,
            unit="B",
            unit_scale=True,
            unit_divisor=1024,
            desc=os.path.basename(output_path),
        ) as bar:
            for chunk in r.iter_content(chunk_size=CHUNK_SIZE):
                if chunk:
                    f.write(chunk)
                    bar.update(len(chunk))

    if expected_sha256:
        print(f"Verifying SHA256 for {os.path.basename(output_path)}...")
        actual = sha256_file(temp_path)
        if actual.lower() != expected_sha256.lower():
            raise ValueError(
                f"Hash mismatch for {output_path}. Expected {expected_sha256}, got {actual}"
            )

    if os.path.exists(output_path):
        os.remove(output_path)
    os.rename(temp_path, output_path)
    return True


def download_all_parts(manifest):
    os.makedirs(PARTS_DIR, exist_ok=True)
    part_paths = []

    for index, file_info in enumerate(manifest["files"], start=1):
        url = file_info["url"]
        filename = file_info.get("name") or f"paks.zip.{index:03d}"
        expected_sha = file_info.get("sha256")
        output_path = os.path.join(PARTS_DIR, filename)
        part_paths.append(output_path)

        if os.path.exists(output_path):
            if expected_sha:
                try:
                    if sha256_file(output_path).lower() == expected_sha.lower():
                        print(f"Part already downloaded and verified: {filename}")
                        continue
                    else:
                        print(f"Existing part failed hash check, redownloading: {filename}")
                        os.remove(output_path)
                except Exception:
                    os.remove(output_path)
            else:
                print(f"Part already exists, skipping: {filename}")
                continue

        download_file(url, output_path, expected_sha256=expected_sha)

    return part_paths


def merge_parts(part_paths, output_zip_path):
    temp_zip_path = output_zip_path + ".merge"

    if os.path.exists(temp_zip_path):
        os.remove(temp_zip_path)

    print("Merging downloaded parts into paks.zip...")
    total_size = sum(os.path.getsize(p) for p in part_paths)

    with open(temp_zip_path, "wb") as outfile, tqdm(
        total=total_size,
        unit="B",
        unit_scale=True,
        unit_divisor=1024,
        desc="Merging",
    ) as bar:
        for part in part_paths:
            with open(part, "rb") as infile:
                while True:
                    chunk = infile.read(CHUNK_SIZE)
                    if not chunk:
                        break
                    outfile.write(chunk)
                    bar.update(len(chunk))

    if os.path.exists(output_zip_path):
        os.remove(output_zip_path)
    os.rename(temp_zip_path, output_zip_path)
    print(f"Merged ZIP created: {output_zip_path}")


def download_latest_file(manifest):
    if os.path.exists(ZIP_FILE_PATH):
        os.remove(ZIP_FILE_PATH)

    part_paths = download_all_parts(manifest)
    merge_parts(part_paths, ZIP_FILE_PATH)

    if os.path.exists(ZIP_FILE_PATH) and os.path.getsize(ZIP_FILE_PATH) > 1000:
        size_gb = os.path.getsize(ZIP_FILE_PATH) / (1024 ** 3)
        print(f"Final ZIP size: {size_gb:.2f} GB")
        return True

    print("Download or merge failed.")
    return False


# -----------------------------
# Extraction
# -----------------------------
def unzip_file(zip_file_path, destination_folder):
    try:
        os.makedirs(destination_folder, exist_ok=True)
        print("Testing ZIP file before extraction...")
        with zipfile.ZipFile(zip_file_path, "r") as zip_ref:
            bad_file = zip_ref.testzip()
            if bad_file:
                print(f"ZIP test failed. First bad file: {bad_file}")
                return False

            print(f"Extracting to: {destination_folder}")
            members = zip_ref.infolist()
            total_size = sum(m.file_size for m in members)

            with tqdm(total=total_size, unit="B", unit_scale=True, unit_divisor=1024, desc="Extracting") as bar:
                for member in members:
                    target_path = os.path.join(destination_folder, member.filename)
                    if os.path.exists(target_path):
                        try:
                            if os.path.isdir(target_path):
                                shutil.rmtree(target_path)
                            else:
                                os.remove(target_path)
                        except PermissionError:
                            print(f"Warning: Could not remove {target_path}. Check permissions.")

                    zip_ref.extract(member, destination_folder)
                    bar.update(member.file_size)

        print(f"Successfully extracted {zip_file_path} to {destination_folder}")
        return True

    except zipfile.BadZipFile:
        print("Error: The merged file is not a valid zip file.")
    except PermissionError:
        print("Error: Permission denied. Try running as administrator or selecting another folder.")
    except Exception as e:
        print(f"Unexpected extraction error: {e}")
    return False


# -----------------------------
# Main
# -----------------------------
def main():
    config = load_config()
    manifest = get_manifest()
    latest_signature = manifest_signature(manifest)
    last_signature = config.get("last_manifest_signature")

    print(f"Latest version: {manifest.get('version')}")

    if last_signature != latest_signature:
        print("Update detected! Removing old ZIP and downloading latest parts...")
        if os.path.exists(ZIP_FILE_PATH):
            os.remove(ZIP_FILE_PATH)
        # Keep old part files only if names/hash match; mismatched parts get redownloaded.
        config["last_manifest_signature"] = latest_signature
        config["last_version"] = manifest.get("version")
        save_config(config)

    if not os.path.exists(ZIP_FILE_PATH):
        success = download_latest_file(manifest)
        if not success:
            print("Failed to download/merge ZIP file.")
            input("Press Enter to exit...")
            return
    else:
        print("ZIP file already exists. Skipping download.")

    destination_folder = config.get("destination_folder")
    if not destination_folder:
        print("No saved path found. Trying to auto-detect ARK install...")
        destination_folder = find_ark_install_path()
        if destination_folder:
            print(f"Auto-detected ARK path: {destination_folder}")
            config["destination_folder"] = destination_folder.replace("\\", "/")
            save_config(config)
        else:
            print("Could not auto-detect ARK install. Please select folder manually.")
            destination_folder = select_destination_folder(config)

    if destination_folder:
        print(f"Using destination: {destination_folder}")
        unzip_file(ZIP_FILE_PATH, destination_folder)
    else:
        print("No folder selected. Exiting...")

    input("Press Enter to exit...")


if __name__ == "__main__":
    try:
        main()
    except Exception:
        import traceback
        print("\nERROR:")
        traceback.print_exc()
        input("\nPress Enter to exit...")
